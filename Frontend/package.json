{
  "name": "r-3-love",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "tw:build": "tailwindcss -i ./src/tailwind.css -o ./src/tailwind-output.css",
    "tw:watch": "tailwindcss -i ./src/tailwind.css -o ./src/tailwind-output.css --watch",
    "prestart": "npm run tw:build",
    "prebuild": "npm run tw:build",
    "prewatch": "npm run tw:build",
    "start": "concurrently -k -n tw,ng \"npm:tw:watch\" \"ng serve\"",
    "build": "ng build",
    "watch": "concurrently -k -n tw,ng \"npm:tw:watch\" \"ng build --watch --configuration development\"",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@10.9.3",
  "dependencies": {
    "@angular/cdk": "21.0.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@spartan-ng/brain": "^0.0.1-alpha.706",
    "@tailwindcss/postcss": "^4.3.0",
    "angular-calendar": "^0.32.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-angular": "^1.0.0",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.5.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.14",
    "@angular/cli": "^21.2.14",
    "@angular/compiler-cli": "^21.2.0",
    "@spartan-ng/cli": "^0.0.1-alpha.706",
    "@tailwindcss/cli": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.1",
    "postcss-nesting": "^14.0.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
