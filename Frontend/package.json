{
  "name": "r-3-love",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "tw:build": "tailwindcss -i ./src/tailwind.css -o ./src/tailwind-output.css",
    "tw:watch": "tailwindcss -i ./src/tailwind.css -o ./src/tailwind-output.css --watch",
    "prestart": "npm run tw:build",
    "prebuild": "npm run tw:build",
    "prewatch": "npm run tw:build",
    "start": "concurrently -k -n tw,ng \"npm:tw:watch\" \"ng serve\"",
    "build": "ng build",
    "watch": "concurrently -k -n tw,ng \"npm:tw:watch\" \"ng build --watch --configuration development\"",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@10.9.3",
  "dependencies": {
    "@angular/animations": "^20.1.8",
    "@angular/cdk": "21.0.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@apollo/client": "^4.2.3",
    "@ng-icons/core": ">=32.0.0 <34.0.0",
    "@ng-icons/lucide": ">=32.0.0 <34.0.0",
    "@spartan-ng/brain": "^0.0.1-alpha.706",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/three": "^0.185.1",
    "angular-calendar": "^0.32.2",
    "angular-draggable-droppable": "^9.0.1",
    "angular-resizable-element": "^8.0.3",
    "apollo-angular": "^14.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "country-list": "^2.4.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "flag-icons": "^7.5.0",
    "graphql": "^16.14.2",
    "i18n-iso-countries": "^7.14.0",
    "lucide-angular": "^1.0.0",
    "ngx-toastr": "^19.1.0",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.185.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.14",
    "@angular/cli": "^21.2.14",
    "@angular/compiler-cli": "^21.2.0",
    "@spartan-ng/cli": "^0.0.1-alpha.706",
    "@tailwindcss/cli": "^4.3.0",
    "@types/country-list": "^2.1.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.1",
    "postcss-nesting": "^14.0.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
